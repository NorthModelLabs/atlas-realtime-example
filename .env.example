# Required — Atlas session API
ATLAS_API_KEY=your_atlas_api_key
ATLAS_API_URL=https://api.atlasv1.com

# Optional — enables AI chat responses (LLM)
LLM_API_KEY=your_openai_or_helicone_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Optional — enables voice (TTS) responses
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
